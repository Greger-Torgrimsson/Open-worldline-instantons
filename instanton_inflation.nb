Cell[BoxData[
 RowBox[{"(*", "\"\< \n\nWe do not actually need to choose the asymptotic \
segments along the lines on which the instanton is real,\nbut it is often \
convenient to do so.\n\nHowever, we do not know a priori at which values of \
Im[u] those lines are located. \nWe can deal with this by letting the code \
automatically switch to horizontal contours when Im[t]=0.\n\nThe code also \
automatically stops when the background is essentially flat, \nwhich is \
implemented by stopping when |t''| < \!\(\*SuperscriptBox[\(10\), \(-6\)]\).\n\
\nThis usually occurs at r << 100, but should be checked in other examples.\n\
\n\>\"", "*)"}]], "Input",
 CellChangeTimes->{{3.991024862567829*^9, 3.991024920230587*^9}, {
  3.991049033983778*^9, 3.9910490515945244`*^9}, {3.9910490908241615`*^9, 
  3.99104924507765*^9}, {3.9910494477950134`*^9, 3.9910494498025703`*^9}, {
  3.9910495006491776`*^9, 
  3.9910495674702454`*^9}},ExpressionUUID->"0b93f117-d26c-e343-af53-\
e3da7f44614f"],

