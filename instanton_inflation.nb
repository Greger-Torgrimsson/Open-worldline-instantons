Cell[BoxData[
 RowBox[{"(*", "\"\< \nIn Example 1, we could guess a starting point for \!\(\
\*SuperscriptBox[\(x\), \(\[Mu]\)]\)(0) without any prior work. In Example 2, \
and more generally,\nwe first determine \!\(\*SuperscriptBox[\(x\), \
\(\[Mu]\)]\)(0) for a purely time-dependent metric (\[Beta]=0) and then use \
that solution as the starting point for \[Beta]>0. \n\nThis is explained in:\n\
\nP. Semren and G. Torgrimsson,\n``Worldline instantons for nonperturbative \
particle production by space and time dependent gravitational fields''\nPhys. \
Rev. D \!\(\*StyleBox[\"113\",FontWeight->\"Bold\"]\), 056005 (2026)\n\n\>\"",
   "*)"}]], "Input",
 CellChangeTimes->{{3.991038216950121*^9, 3.9910382578427486`*^9}, {
   3.991050087643406*^9, 3.9910500962347946`*^9}, {3.991055872450983*^9, 
