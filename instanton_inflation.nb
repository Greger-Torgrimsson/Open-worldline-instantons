Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Eta]Eq", "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Eta]", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "r", "]"}], "==", 
    RowBox[{"Simplify", "[", 
     RowBox[{"Expand", "[", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", "\[ImaginaryI]", " ", "\[CurlyPhi]"}]], 
       FractionBox["R", "2"], 
       RowBox[{"\[Eta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"EQS", "=", 
  RowBox[{"Join", "[", 
   RowBox[{"instantonEq", ",", 
    RowBox[{"{", 
     RowBox[{"\[Psi]Eq", ",", "\[Eta]Eq"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9894985981504345`*^9, 3.989498633932611*^9}, {
  3.989547787449534*^9, 3.989547802734167*^9}, {3.989549848202372*^9, 
  3.989549855376446*^9}, {3.990590358003042*^9, 3.990590373385063*^9}},
 CellLabel->"In[92]:=",ExpressionUUID->"6d5c6a76-5057-e345-88ce-284a5ad610cc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["t", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "r", "]"}], "\[Equal]", 
    RowBox[{"2", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", 
           SuperscriptBox[
            RowBox[{"t", "[", "r", "]"}], "2"]}], "-", 
          SuperscriptBox[
           RowBox[{"x", "[", "r", "]"}], "2"]}]]}], "-", 
       SuperscriptBox[
        RowBox[{"t", "[", "r", "]"}], "2"], "-", 
       SuperscriptBox[
        RowBox[{"x", "[", "r", "]"}], "2"]}]], " ", 
     RowBox[{"t", "[", "r", "]"}], " ", 
     SuperscriptBox[
      RowBox[{
       SuperscriptBox["x", "\[Prime]",
        MultilineFunction->None], "[", "r", "]"}], "2"]}]}], ",", 
   RowBox[{
    RowBox[{
     SuperscriptBox["x", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "r", "]"}], "\[Equal]", 
    RowBox[{"2", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox[
         RowBox[{"t", "[", "r", "]"}], "2"]}], "-", 
       SuperscriptBox[
        RowBox[{"x", "[", "r", "]"}], "2"]}]], " ", 
     RowBox[{
      SuperscriptBox["x", "\[Prime]",
       MultilineFunction->None], "[", "r", "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", 
        RowBox[{"t", "[", "r", "]"}], " ", 
        RowBox[{
         SuperscriptBox["t", "\[Prime]",
          MultilineFunction->None], "[", "r", "]"}]}], "+", 
       RowBox[{
        RowBox[{"x", "[", "r", "]"}], " ", 
        RowBox[{
         SuperscriptBox["x", "\[Prime]",
          MultilineFunction->None], "[", "r", "]"}]}]}], ")"}]}]}], ",", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Psi]", "\[Prime]",
      MultilineFunction->None], "[", "r", "]"}], "\[Equal]", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", 
           SuperscriptBox[
            RowBox[{"t", "[", "r", "]"}], "2"]}], "-", 
          SuperscriptBox[
           RowBox[{"x", "[", "r", "]"}], "2"]}]]}], "-", 
       RowBox[{"\[ImaginaryI]", " ", "\[CurlyPhi]"}], "-", 
       SuperscriptBox[
        RowBox[{"t", "[", "r", "]"}], "2"], "-", 
       SuperscriptBox[
        RowBox[{"x", "[", "r", "]"}], "2"]}]], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"t", "[", "r", "]"}], "2"], "+", 
       SuperscriptBox[
        RowBox[{"x", "[", "r", "]"}], "2"]}], ")"}], " ", 
     SuperscriptBox[
      RowBox[{
       SuperscriptBox["x", "\[Prime]",
        MultilineFunction->None], "[", "r", "]"}], "2"]}]}], ",", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Eta]", "\[Prime]\[Prime]",
      MultilineFunction->None], "[", "r", "]"}], "\[Equal]", 
    RowBox[{"2", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[CurlyPhi]"}], "-", 
       RowBox[{"2", " ", 
        SuperscriptBox[
         RowBox[{"t", "[", "r", "]"}], "2"]}], "-", 
       RowBox[{"2", " ", 
        SuperscriptBox[
         RowBox[{"x", "[", "r", "]"}], "2"]}]}]], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"t", "[", "r", "]"}], "2"], "+", 
          SuperscriptBox[
           RowBox[{"x", "[", "r", "]"}], "2"]}]]}], "+", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"t", "[", "r", "]"}], "2"], "+", 
            SuperscriptBox[
             RowBox[{"x", "[", "r", "]"}], "2"]}]]}], ")"}], " ", 
        SuperscriptBox[
         RowBox[{"t", "[", "r", "]"}], "2"]}]}], ")"}], " ", 
     RowBox[{"\[Eta]", "[", "r", "]"}]}]}]}], "}"}]], "Output",
