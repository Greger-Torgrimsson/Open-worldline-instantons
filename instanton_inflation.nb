Cell[BoxData[
 RowBox[{"(*", "\"\< \n\nSince the particle and antiparticle momenta are \
given by p=-P+\!\(\*FractionBox[\(\[CapitalDelta]\), \(2\)]\) and \
q=P+\!\(\*FractionBox[\(\[CapitalDelta]\), \(2\)]\),\nthe relations \
spec11=-spec12 and spec21=-spec22 \nimply that the probability amplitude is \
antisymmetric under particle <-> antiparticle exchange. \n\n\>\"", 
  "*)"}]], "Input",
