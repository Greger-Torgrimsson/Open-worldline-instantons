Cell[BoxData[
 RowBox[{"(*", "\"\< \n\nClick on the panes to choose a contour in the \
complex u plane.\nThe goal is to find a suitable path around the branch \
points.\n\nThe first click creates a segment from u=0 to the selected point.\n\
Each subsequent click adds another segment to the contour.\n\nClicking near \
the left border adds a horizontal segment for the asymptotic antiparticle.\n\
This segment extends beyond the plotted region to r=100, \nwhich is usually \
more than sufficient for the instanton to reach Minkowski space.\n\nFor the \
saddle-point momenta p=\!\(\*SubscriptBox[\(p\), \(s\)]\) and \
q=\!\(\*SubscriptBox[\(q\), \(s\)]\), the instanton is real along this \
horizontal segment.\nWe then call it the antiparticle acceleration region, \n\
as the instanton still feels the background but has left the complex creation \
region.\n\nThe antiparticle half of the contour is then complete and is \
stored in \[CurlyPhi]InTab and rInTab.\n\nThe next click starts the particle \
half of the contour by creating a segment from u=0 to the selected point.\n\
Subsequent clicks add further segments.\n\nClicking near the right border \
adds a horizontal segment for the asymptotic particle.\nFor \
p=\!\(\*SubscriptBox[\(p\), \(s\)]\) and q=\!\(\*SubscriptBox[\(q\), \
\(s\)]\), the instanton is real along this segment and we call it the \
particle acceleration region.\n\nThe particle half of the contour is then \
complete and is stored in \[CurlyPhi]OutTab and rOutTab.\n\n\>\"", 
  "*)"}]], "Input",
 CellChangeTimes->{{3.9894950977432137`*^9, 3.9894951567728157`*^9}, {
  3.9910239573046684`*^9, 3.9910240498143253`*^9}, {3.991037139129347*^9, 
  3.9910372047725983`*^9}, {3.9910473133177795`*^9, 3.991047340288391*^9}, {
  3.9910474709809628`*^9, 3.9910478540139256`*^9}, {3.9910479130870476`*^9, 
