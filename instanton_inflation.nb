 RowBox[{
  RowBox[{"stopInTab", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Im", "[", 
       RowBox[{"t", "[", "r", "]"}], "]"}], "==", "0"}], ",", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"t", "''"}], "[", "r", "]"}], "]"}], "<", 
      SuperscriptBox["10", 
       RowBox[{"-", "6"}]]}]}], "}"}]}], ";", " ", 
  RowBox[{"stopOutTab", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Im", "[", 
       RowBox[{"t", "[", "r", "]"}], "]"}], "==", "0"}], ",", 
     RowBox[{
