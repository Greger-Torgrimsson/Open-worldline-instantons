       RowBox[{
        RowBox[{"t", "''"}], "[", "r", "]"}], "]"}], "<", 
      SuperscriptBox["10", 
       RowBox[{"-", "6"}]]}]}], "}"}]}], ";"}]], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"ab8a3c6d-1ddb-6c45-bf62-b43e36a65f26"],

