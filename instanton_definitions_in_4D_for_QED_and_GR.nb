Cell[BoxData[
 RowBox[{
  RowBox[{"makeEq", "[", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"xu", "=", 
      RowBox[{"{", 
       RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"xur", "[", "r_", "]"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"t", "[", "r", "]"}], ",", 
        RowBox[{"x", "[", "r", "]"}], ",", 
        RowBox[{"y", "[", "r", "]"}], ",", 
        RowBox[{"z", "[", "r", "]"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Delta]xu", "=", 
      RowBox[{"{", 
       RowBox[{
       "\[Delta]t", ",", "\[Delta]x", ",", "\[Delta]y", ",", "\[Delta]z"}], 
       "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Delta]xur", "[", "r_", "]"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Delta]t", "[", "r", "]"}], ",", 
        RowBox[{"\[Delta]x", "[", "r", "]"}], ",", 
        RowBox[{"\[Delta]y", "[", "r", "]"}], ",", 
        RowBox[{"\[Delta]z", "[", "r", "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"gdd", "=", "g\[Mu]\[Nu]"}], ";", " ", 
     RowBox[{"guu", "=", 
      RowBox[{"Inverse", "[", "gdd", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"gddd", "=", 
      RowBox[{"Grad", "[", 
       RowBox[{"gdd", ",", "xu"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[CapitalGamma]udd", "=", 
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{"guu", ".", 
        RowBox[{"(", 
         RowBox[{"gddd", "+", 
          RowBox[{"Transpose", "[", 
           RowBox[{"gddd", ",", 
            RowBox[{"2", "\[TwoWayRule]", "3"}]}], "]"}], "-", 
          RowBox[{"Transpose", "[", 
           RowBox[{"gddd", ",", 
            RowBox[{"1", "\[TwoWayRule]", "3"}]}], "]"}]}], ")"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[CapitalGamma]uddd", "=", 
      RowBox[{"Grad", "[", 
       RowBox[{"\[CapitalGamma]udd", ",", "xu"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[CapitalGamma]\[CapitalGamma]", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{
        RowBox[{"\[CapitalGamma]udd", ".", "\[CapitalGamma]udd"}], ",", 
        RowBox[{"2", "\[TwoWayRule]", "3"}]}], "]"}]}], ";", 
     RowBox[{"Ruddd", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"Transpose", "[", 
         RowBox[{"\[CapitalGamma]uddd", ",", 
          RowBox[{"3", "\[TwoWayRule]", "4"}]}], "]"}], "-", 
        "\[CapitalGamma]uddd", "+", "\[CapitalGamma]\[CapitalGamma]", "-", 
        RowBox[{"Transpose", "[", 
         RowBox[{"\[CapitalGamma]\[CapitalGamma]", ",", 
          RowBox[{"3", "\[TwoWayRule]", "4"}]}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Rdd", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"Ruddd", "[", 
            RowBox[{"[", 
             RowBox[{"\[Rho]", ",", "\[Mu]", ",", "\[Nu]", ",", "\[Rho]"}], 
             "]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"\[Rho]", ",", "4"}], "}"}]}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Mu]", ",", "4"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Nu]", ",", "4"}], "}"}]}], "]"}]}], ";", 
     RowBox[{"R", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"guu", "[", 
           RowBox[{"[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}], 
          RowBox[{"Rdd", "[", 
           RowBox[{"[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Mu]", ",", "4"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Nu]", ",", "4"}], "}"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"minor", "[", 
       RowBox[{"\[CapitalMu]_", ",", "\[CapitalNu]_"}], "]"}], ":=", 
      RowBox[{"Det", "[", 
       RowBox[{"gdd", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"\[CapitalMu]", "+", "1"}], ",", 
          RowBox[{"\[CapitalNu]", "+", "1"}]}], "]"}], "]"}], "]"}]}], ";", 
     RowBox[{"eud", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          FractionBox[
           SqrtBox[
            RowBox[{"-", 
             RowBox[{"minor", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}]}], 
              "]"}]}]], 
           SqrtBox[
            RowBox[{"-", 
             RowBox[{"minor", "[", 
