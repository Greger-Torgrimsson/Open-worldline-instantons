                  RowBox[{"-", "1"}]}], "]"}], "]"}]}], ";", 
              RowBox[{"\[CurlyPhi]OutTab", "=", 
               RowBox[{
                RowBox[{
                 RowBox[{"ArcTan", "[", 
                  RowBox[{"#1", ",", "#2"}], "]"}], "&"}], "@@@", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"RotateLeft", "[", "pts2", "]"}], "-", "pts2"}], 
                  ")"}], "[", 
                 RowBox[{"[", 
                  RowBox[{"1", ";;", 
                   RowBox[{"-", "2"}]}], "]"}], "]"}]}]}], ";", 
              RowBox[{"rOutTab", "=", 
               RowBox[{
                RowBox[{
                 RowBox[{"Norm", "[", "#", "]"}], "&"}], "/@", 
