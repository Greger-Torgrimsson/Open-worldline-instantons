Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"Ruddd", "[", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"\[Mu]", "+", "1"}], ",", 
      RowBox[{"\[Alpha]", "+", "1"}], ",", 
      RowBox[{"\[Beta]", "+", "1"}], ",", 
      RowBox[{"\[Gamma]", "+", "1"}]}], "]"}], "]"}], "=", 
   RowBox[{
    SubsuperscriptBox["R", "\[Alpha]\[Beta]\[Gamma]", "\[Mu]"], "=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalGamma]", 
      RowBox[{"\[Alpha]\[Gamma]", ",", "\[Beta]"}], "\[Mu]"], "-", 
     SubsuperscriptBox["\[CapitalGamma]", 
      RowBox[{"\[Alpha]\[Beta]", ",", "\[Gamma]"}], "\[Mu]"], "+", 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", "\[Beta]\[Lambda]", "\[Mu]"], 
      SubsuperscriptBox["\[CapitalGamma]", "\[Alpha]\[Gamma]", "\[Lambda]"]}],
      "-", 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", "\[Gamma]\[Lambda]", "\[Mu]"], 
      SubsuperscriptBox["\[CapitalGamma]", "\[Alpha]\[Beta]", 
       "\[Lambda]"]}]}]}]}], " ", "*)"}]], "Input",
 CellChangeTimes->{{3.979967026898983*^9, 3.979967147248861*^9}, {
  3.9799701833090076`*^9, 3.9799702317357235`*^9}, {3.9894923704024296`*^9, 
