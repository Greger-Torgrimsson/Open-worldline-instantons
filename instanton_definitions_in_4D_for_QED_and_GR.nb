                  RowBox[{"pts", "[", 
                   RowBox[{"[", 
                    RowBox[{
                    RowBox[{"-", "1"}], ",", "2"}], "]"}], "]"}]}], "}"}]}], 
               "]"}], ";", " ", 
              RowBox[{"pts2", "=", 
               RowBox[{"pts", "[", 
                RowBox[{"[", 
