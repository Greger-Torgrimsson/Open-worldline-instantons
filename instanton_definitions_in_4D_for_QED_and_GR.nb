Cell[BoxData[
 RowBox[{
  RowBox[{"expand\[Psi]", "[", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"q0s", "=", 
      RowBox[{"chop", "[", 
       RowBox[{"-", 
        RowBox[{"dxuIn", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"p0s", "=", 
      RowBox[{"chop", "[", 
       RowBox[{"dxuOut", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"qxs", "=", 
      RowBox[{"chop", "[", 
       RowBox[{"-", 
        RowBox[{"dxuIn", "[", 
         RowBox[{"[", 
          RowBox[{"2", ";;", 
           RowBox[{"-", "1"}]}], "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pxs", "=", 
      RowBox[{"chop", "[", 
       RowBox[{"dxuOut", "[", 
        RowBox[{"[", 
         RowBox[{"2", ";;", 
          RowBox[{"-", "1"}]}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[Psi]q", "=", 
      RowBox[{"chop", "[", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"xuIn", "[", 
           RowBox[{"[", 
            RowBox[{"2", ";;", 
             RowBox[{"-", "1"}]}], "]"}], "]"}], "-", 
          RowBox[{
           FractionBox["qxs", "q0s"], 
           RowBox[{"xuIn", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}]}], ")"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Psi]p", "=", 
      RowBox[{"chop", "[", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"xuOut", "[", 
           RowBox[{"[", 
            RowBox[{"2", ";;", 
             RowBox[{"-", "1"}]}], "]"}], "]"}], "-", 
          RowBox[{
           FractionBox["pxs", "p0s"], 
           RowBox[{"xuOut", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}]}], ")"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"aVec", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        SubscriptBox["a", "j"], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", 
          RowBox[{"2", "dim"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Delta]In", "=", 
      RowBox[{"\[Delta]xuIn", ".", "aVec"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Delta]Out", "=", 
      RowBox[{"\[Delta]xuOut", ".", "aVec"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"d\[Delta]In", "=", 
      RowBox[{"d\[Delta]xuIn", ".", "aVec"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"d\[Delta]Out", "=", 
      RowBox[{"d\[Delta]xuOut", ".", "aVec"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"abPositron", "=", 
      RowBox[{"chop", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"d\[Delta]In", "==", 
               RowBox[{"Prepend", "[", 
                RowBox[{
                 RowBox[{"UnitVector", "[", 
                  RowBox[{
                   RowBox[{"dim", "-", "1"}], ",", "j"}], "]"}], ",", 
                 FractionBox[
                  RowBox[{"qxs", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "q0s"]}], "]"}]}], ",", 
              RowBox[{"d\[Delta]Out", "==", 
               RowBox[{"Table", "[", 
                RowBox[{"0", ",", "dim"}], "]"}]}]}], "}"}], ",", "aVec"}], 
           "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"abElectron", "=", 
      RowBox[{"chop", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Solve", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"d\[Delta]In", "==", 
               RowBox[{"Table", "[", 
                RowBox[{"0", ",", "dim"}], "]"}]}], ",", 
              RowBox[{"d\[Delta]Out", "==", 
               RowBox[{"Prepend", "[", 
                RowBox[{
                 RowBox[{"-", 
                  RowBox[{"UnitVector", "[", 
                   RowBox[{
                    RowBox[{"dim", "-", "1"}], ",", "j"}], "]"}]}], ",", 
                 RowBox[{"-", 
                  FractionBox[
                   RowBox[{"pxs", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "p0s"]}]}], "]"}]}]}], 
             "}"}], ",", "aVec"}], "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"tIn", "=", 
      RowBox[{"xuIn", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"tOut", "=", 
      RowBox[{"xuOut", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Psi]qq", "=", 
      RowBox[{"chop", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[ImaginaryI]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Delta]In", "[", 
              RowBox[{"[", 
               RowBox[{"k", "+", "1"}], "]"}], "]"}], "-", 
             RowBox[{
              FractionBox[
               RowBox[{"qxs", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "q0s"], 
              RowBox[{"\[Delta]In", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 SuperscriptBox["q0s", "2"], 
                 RowBox[{"KroneckerDelta", "[", 
                  RowBox[{"k", ",", "l"}], "]"}]}], "-", 
                RowBox[{
                 RowBox[{"qxs", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], 
                 RowBox[{"qxs", "[", 
                  RowBox[{"[", "l", "]"}], "]"}]}]}], ")"}], 
              FractionBox["tIn", 
               SuperscriptBox["q0s", "3"]]}]}], ")"}]}], "/.", 
          RowBox[{"abPositron", "[", 
           RowBox[{"[", "l", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"l", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[Psi]pp", "=", 
      RowBox[{"chop", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[ImaginaryI]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Delta]Out", "[", 
              RowBox[{"[", 
               RowBox[{"k", "+", "1"}], "]"}], "]"}], "-", 
             RowBox[{
              FractionBox[
               RowBox[{"pxs", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "p0s"], 
              RowBox[{"\[Delta]Out", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 SuperscriptBox["p0s", "2"], 
                 RowBox[{"KroneckerDelta", "[", 
                  RowBox[{"k", ",", "l"}], "]"}]}], "-", 
                RowBox[{
                 RowBox[{"pxs", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], 
                 RowBox[{"pxs", "[", 
                  RowBox[{"[", "l", "]"}], "]"}]}]}], ")"}], 
              FractionBox["tOut", 
               SuperscriptBox["p0s", "3"]]}]}], ")"}]}], "/.", 
          RowBox[{"abElectron", "[", 
           RowBox[{"[", "l", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"l", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[Psi]qp", "=", 
      RowBox[{"chop", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[ImaginaryI]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Delta]In", "[", 
              RowBox[{"[", 
               RowBox[{"k", "+", "1"}], "]"}], "]"}], "-", 
             RowBox[{
              FractionBox[
               RowBox[{"qxs", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "q0s"], 
              RowBox[{"\[Delta]In", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}]}], ")"}]}], "/.", 
          RowBox[{"abElectron", "[", 
           RowBox[{"[", "l", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"l", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[Psi]pq", "=", 
      RowBox[{"chop", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[ImaginaryI]", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Delta]Out", "[", 
              RowBox[{"[", 
               RowBox[{"k", "+", "1"}], "]"}], "]"}], "-", 
             RowBox[{
              FractionBox[
               RowBox[{"pxs", "[", 
                RowBox[{"[", "k", "]"}], "]"}], "p0s"], 
              RowBox[{"\[Delta]Out", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}]}], ")"}]}], "/.", 
          RowBox[{"abPositron", "[", 
           RowBox[{"[", "l", "]"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"l", ",", 
           RowBox[{"dim", "-", "1"}]}], "}"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"qpFromP\[CapitalDelta]", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", 
          FractionBox["1", "2"]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", 
          FractionBox["1", "2"]}], "}"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Psi]P", "=", 
      RowBox[{"chop", "[", 
       RowBox[{"\[Psi]q", "-", "\[Psi]p"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
