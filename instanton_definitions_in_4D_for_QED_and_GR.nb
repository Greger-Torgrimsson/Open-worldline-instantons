 CellLabel->"In[1]:=",ExpressionUUID->"6c5acedb-1ba0-be43-a1bd-dc082bd2c2a4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"w3", "=", 
   RowBox[{"Collect", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"quad", "[", "q3", "]"}], "/.", 
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"quad", "[", "q0", "]"}], "==", "w0"}], ",", 
           RowBox[{
            RowBox[{"quad", "[", "q1", "]"}], "==", "w1"}], ",", 
           RowBox[{
            RowBox[{"quad", "[", "q2", "]"}], "==", "w2"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"c0", ",", "c1", ",", "c2"}], "}"}]}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"w0", ",", "w1", ",", "w2"}], "}"}], ",", "FullSimplify"}], 
    "]"}]}], ";"}]], "Input",
