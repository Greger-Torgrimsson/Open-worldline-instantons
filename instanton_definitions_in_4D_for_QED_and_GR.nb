Cell[BoxData[
 RowBox[{"(*", "\"\< \n\nThe formulas for the functional determinant and the \
quadratic-instanton approximation are explained in:\[IndentingNewLine]\nG. \
Degli Esposti and G. Torgrimsson,\n``Worldline instantons for the momentum \
spectrum of Schwinger pair production in spacetime dependent fields''\nPhys. \
Rev. D \!\(\*StyleBox[\"107\",FontWeight->\"Bold\"]\), 056019 (2023)\n\nG. \
Degli Esposti and G. Torgrimsson,\n``Momentum spectrum of Schwinger pair \
production in four-dimensional e-dipole fields''\nPhys. Rev. D \
\!\(\*StyleBox[\"109\",FontWeight->\"Bold\"]\), 016013 (2024)\
\[IndentingNewLine]\nG. Degli Esposti and G. Torgrimsson,\n``Momentum \
spectrum of nonlinear Breit-Wheeler pair production in spacetime fields''\n\
Phys. Rev. D \!\(\*StyleBox[\"110\",FontWeight->\"Bold\"]\), 076017 (2024)\
\[IndentingNewLine]\nG. Torgrimsson,\n``Solving the Dirac equation on a GPU \
for strong-field processes in multidimensional background fields''\n\
arXiv:2512.16889[hep-ph] \[IndentingNewLine]\n\>\"", "*)"}]], "Input",
 CellChangeTimes->{{3.9910396439511375`*^9, 3.9910399020686913`*^9}, {
