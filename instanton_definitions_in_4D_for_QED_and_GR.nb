Cell[CellGroupData[{

Cell["Segment", "Subsection",
 CellChangeTimes->{{3.95654802061111*^9, 3.956548034893364*^9}, {
   3.956831022593418*^9, 3.9568310297092133`*^9}, {3.956838219194271*^9, 
   3.956838221716696*^9}, 
   3.958045128010678*^9},ExpressionUUID->"78d6e721-2479-284b-976e-\
ed8050f74275"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "segment", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"stopAt", "->", "\"\<no\>\""}], ",", 
      RowBox[{"rMin", "->", "0"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"segment", "[", "]"}], " ", "solves", " ", 
        SuperscriptBox[
         OverscriptBox["x", ".."], "\[Mu]"]}], "=."}], ".."}], " ", "and"}], ",",
     " ", 
    RowBox[{"depending", " ", "on", " ", "options"}], ",", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         OverscriptBox["\[Psi]", "."], "=."}], ".."}], " ", "and", " ", 
       "\[Delta]", 
       SuperscriptBox[
        OverscriptBox["x", ".."], "\[Mu]"]}], "=."}], ".."}], ",", " ", 
    RowBox[{
     RowBox[{
     "along", " ", "a", " ", "straight", " ", "line", " ", "in", " ", "the", " ",
       "complex", " ", "proper"}], "-", 
     RowBox[{"time", " ", "plane"}]}], ",", " ", 
    RowBox[{"u", "=", 
     SuperscriptBox["r\[ExponentialE]", "\[ImaginaryI]\[CurlyPhi]"]}], ",", 
    " ", 
    RowBox[{"0", "<", "r", "<", 
     RowBox[{"r0", "."}]}]}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"segment", "[", 
    RowBox[{
     RowBox[{"\[CurlyPhi]d_", "?", "NumericQ"}], ",", 
     RowBox[{"rMd_", "?", "NumericQ"}], ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[CurlyPhi]", "=", "\[CurlyPhi]d"}], "}"}], ",", " ", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"r0", "=", "rMd"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"Which", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"OptionValue", "[", "stopAt", "]"}], "===", "\"\<no\>\""}], ",",
         " ", 
        RowBox[{"stopCondition", "=", "Nothing"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"OptionValue", "[", "stopAt", "]"}], 
         "===", "\"\<real t\>\""}], ",", 
        RowBox[{"stopCondition", "=", 
         RowBox[{"WhenEvent", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Im", "[", 
             RowBox[{"t", "[", "r", "]"}], "]"}], "==", "0"}], ",", 
           RowBox[{
            RowBox[{"r0", "=", "r"}], ";", " ", "\"\<StopIntegration\>\""}]}],
           "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"OptionValue", "[", "stopAt", "]"}], 
         "===", "\"\<real x\>\""}], ",", 
        RowBox[{"stopCondition", "=", 
         RowBox[{"WhenEvent", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Im", "[", 
             RowBox[{"x", "[", "r", "]"}], "]"}], "==", "0"}], ",", 
           RowBox[{
            RowBox[{"r0", "=", "r"}], ";", " ", "\"\<StopIntegration\>\""}]}],
           "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"OptionValue", "[", "stopAt", "]"}], 
         "===", "\"\<free x\>\""}], ",", 
        RowBox[{"stopCondition", "=", 
         RowBox[{"WhenEvent", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"x", "''"}], "[", "r", "]"}], "]"}], "<", 
            SuperscriptBox["10", 
             RowBox[{"-", "6"}]]}], ",", 
           RowBox[{
            RowBox[{"r0", "=", "r"}], ";", " ", "\"\<StopIntegration\>\""}]}],
           "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"OptionValue", "[", "stopAt", "]"}], 
         "===", "\"\<free t\>\""}], ",", 
        RowBox[{"stopCondition", "=", 
         RowBox[{"WhenEvent", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"t", "''"}], "[", "r", "]"}], "]"}], "<", 
            SuperscriptBox["10", 
             RowBox[{"-", "6"}]]}], ",", 
           RowBox[{
            RowBox[{"r0", "=", "r"}], ";", " ", "\"\<StopIntegration\>\""}]}],
           "]"}]}], ",", "\[IndentingNewLine]", "True", ",", 
        RowBox[{"stopCondition", "=", 
         RowBox[{"WhenEvent", "[", 
          RowBox[{
           RowBox[{"Evaluate", "[", 
            RowBox[{"OptionValue", "[", "stopAt", "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"r0", "=", "r"}], ";", " ", "\"\<StopIntegration\>\""}]}],
           "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"INITS", "=", 
       RowBox[{"Thread", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", "0", "]"}], "&"}], "/@", "var"}], ")"}], "==", 
         "var0"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"dINITS", "=", 
       RowBox[{
        RowBox[{"Thread", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"#", "'"}], "[", "0", "]"}], "&"}], "/@", "var"}], 
           ")"}], "==", 
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"\[ImaginaryI]", " ", "\[CurlyPhi]"}]], "dvar0"}]}], 
         "]"}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"\[Psi]", "'"}], "[", "0", "]"}], "==", "_"}], "->", 
          "Nothing"}], "}"}]}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"varL", "=", 
       RowBox[{"NDSolveValue", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{"{", 
           RowBox[{"EQS", ",", "INITS", ",", "dINITS", ",", "stopCondition"}],
            "}"}], "]"}], ",", "var", ",", 
         RowBox[{"{", 
          RowBox[{"r", ",", 
           RowBox[{"OptionValue", "[", "rMin", "]"}], ",", "rMd"}], "}"}], ",", 
         RowBox[{"WorkingPrecision", "->", "WP"}], ",", 
         RowBox[{"PrecisionGoal", "->", "PG"}], ",", 
         RowBox[{"AccuracyGoal", "->", "AG"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"var0", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", "r0", "]"}], "&"}], "/@", "varL"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dvar0", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          FractionBox["1", 
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"\[ImaginaryI]", " ", "\[CurlyPhi]"}]]], 
          RowBox[{
           RowBox[{"#", "'"}], "[", "r0", "]"}]}], "&"}], "/@", "varL"}]}], 
      ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98586209411545*^9, 3.98586209535927*^9}, {
  3.9858630166394997`*^9, 3.9858630217759037`*^9}, {3.989489117672069*^9, 
  3.9894891179946194`*^9}, {3.9905260107270536`*^9, 3.990526013551264*^9}, {
  3.9905261164843597`*^9, 3.9905261169001274`*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"432c1dfe-72e1-754d-a044-3bbcc2b09ebc"],

