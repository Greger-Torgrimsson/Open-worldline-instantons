Cell[CellGroupData[{

Cell["Riemann sheet", "Subsection",
 CellChangeTimes->{{3.957323879776819*^9, 3.957323890199028*^9}, {
  3.9581126829777*^9, 
  3.958112684272793*^9}},ExpressionUUID->"cfe00760-6831-d44b-9d77-\
b47dd8b12440"],

Cell[BoxData[
 RowBox[{"(*", "\"\<\n\nPlot Riemann sheets for t(u), x(u), t'(u) or x'(u) \
over the complex proper-time u plane as proposed in:\n\nG. Degli Esposti and \
G. Torgrimsson,\n``Momentum spectrum of Schwinger pair production in \
four-dimensional e-dipole fields''\nPhys. Rev. D \
\!\(\*StyleBox[\"109\",FontWeight->\"Bold\"]\), 016013 (2024)\
\[IndentingNewLine]\nG. Degli Esposti and G. Torgrimsson,\n``Momentum \
spectrum of nonlinear Breit-Wheeler pair production in spacetime fields''\n\
Phys. Rev. D \!\(\*StyleBox[\"110\",FontWeight->\"Bold\"]\), 076017 (2024)\
\[IndentingNewLine]\nG. Degli Esposti and G. Torgrimsson,\n``Schwinger pair \
production in spacetime fields: Moir{\\'e} patterns, Aharonov-Bohm phases, \
and Sturm-Liouville eigenvalues''\nPhys. Rev. D \
\!\(\*StyleBox[\"112\",FontWeight->\"Bold\"]\), 016026 (2025)\n\n\>\"", 
  "*)"}]], "Input",
 CellChangeTimes->{{3.9910454217663727`*^9, 3.9910454599595222`*^9}, 
   3.991046373401291*^9},ExpressionUUID->"2b98950e-f677-3f4e-88a8-\
d91f476baa57"],

Cell[BoxData[
 RowBox[{"(*", "\"\< \n\nsheet[...] integrates \!\(\*SuperscriptBox[\(x\), \(\
\[Mu]\)]\)(u) from initial conditions at u=uo, first along a ray with \
u'(r)=\!\(\*SuperscriptBox[\(\[ExponentialE]\), \
\(\[ImaginaryI]\[CurlyPhi]y\)]\),\nand then along a dense set of horizontal \
lines originating from that ray. This produces horizontal branch cuts. \n\nWe \
usually choose the origin of the complex u plane to coincide with a point \
where t'(0)=0. \[IndentingNewLine]\nDifferent parts of the Riemann surface \
can then be explored by choosing different values of \[CurlyPhi]y. \nFor \
example, if there is a branch point at u=\[ImaginaryI], then \[CurlyPhi]y=.45\
\[Pi] gives a branch cut from u=\[ImaginaryI] to \
u=-\[Infinity]+\[ImaginaryI], \nwhile \[CurlyPhi]y=.55\[Pi] gives a branch \
cut from u=\[ImaginaryI] to u=+\[Infinity]+\[ImaginaryI]. \nChoosing \
different values of \[CurlyPhi]y is usually enough to determine a suitable \
contour.\[IndentingNewLine]\nHowever, changing \[CurlyPhi]y alone is \
generally not sufficient to reveal the entire Riemann surface. \nTo move \
around on the Riemann surface, we can first plot the sheet obtained for uo=0 \
and some value of \[CurlyPhi]y. \nWe then choose a new value of uo, compute \
\!\(\*SuperscriptBox[\(x\), \(\[Mu]\)]\)[uo] and \!\(\*SuperscriptBox[\(x\), \
\(\[Mu]\)]\)'[uo] and call sheet[] again. \nRepeating this procedure allows \
us to move around branch points and explore other parts of the Riemann \
surface. \n\n\>\"", "*)"}]], "Input",
 CellChangeTimes->{{3.9910437430785103`*^9, 3.9910437453199863`*^9}, {
   3.991043786898657*^9, 3.9910438983862953`*^9}, {3.9910439378125706`*^9, 
   3.991043962071945*^9}, {3.9910448507125683`*^9, 3.991044878147833*^9}, {
   3.991044911681761*^9, 3.9910449159815865`*^9}, {3.9910454716809654`*^9, 
   3.9910455137022495`*^9}, {3.9910455438172455`*^9, 
   3.9910455503182926`*^9}, {3.991045615268278*^9, 3.9910456974457817`*^9}, {
   3.9910463979560356`*^9, 3.991046459972889*^9}, 
   3.9910465203257427`*^9},ExpressionUUID->"c05991e5-61e3-0540-8965-\
c469087fd105"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "sheet", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"repoints", "->", "100"}], ",", 
      RowBox[{"impoints", "->", "100"}], ",", 
      RowBox[{"uo", "->", "0"}], ",", 
      RowBox[{"\[CurlyPhi]y", "->", 
       RowBox[{".5", "\[Pi]"}]}], ",", 
      RowBox[{"Astart", "->", "0"}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sheet", "[", 
    RowBox[{
     RowBox[{"xS_", "?", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"VectorQ", "[", 
         RowBox[{"#", ",", "NumericQ"}], "]"}], "&"}], ")"}]}], ",", 
     RowBox[{"dxS_", "?", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"VectorQ", "[", 
         RowBox[{"#", ",", "NumericQ"}], "]"}], "&"}], ")"}]}], ",", 
     RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "reMin", ",", "reMax", ",", "imMin", ",", "imMax", ",", "rePoints", ",",
        "imPoints", ",", "yy", ",", "uO", ",", "\[CurlyPhi]Y", ",", 
       RowBox[{"\[CurlyPhi]X", "=", "0"}]}], "}"}], ",", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"reMin", ",", "reMax", ",", "imMin", ",", "imMax"}], "}"}], 
       "=", 
       RowBox[{"{", 
        RowBox[{"ReMin", ",", "ReMax", ",", "ImMin", ",", "ImMax"}], "}"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"rePoints", ",", "imPoints", ",", "uO", ",", "\[CurlyPhi]Y"}],
         "}"}], "=", 
       RowBox[{"OptionValue", "[", 
        RowBox[{"{", 
         RowBox[{
         "repoints", ",", "impoints", ",", "uo", ",", "\[CurlyPhi]y"}], "}"}],
         "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"reMin", ",", "reMax"}], "}"}], "=", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"reMin", ",", "reMax"}], "}"}], "-", 
        RowBox[{"Re", "[", "uO", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"imMin", ",", "imMax"}], "}"}], "=", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"imMin", ",", "imMax"}], "}"}], "-", 
        RowBox[{"Im", "[", "uO", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Ymin", "=", 
       FractionBox["imMin", 
        RowBox[{"Sin", "[", "\[CurlyPhi]Y", "]"}]]}], ";", " ", 
      RowBox[{"Ymax", "=", 
       FractionBox["imMax", 
        RowBox[{"Sin", "[", "\[CurlyPhi]Y", "]"}]]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"EQS", "=", "instantonEq"}], ";", " ", 
      RowBox[{"var", "=", "xu"}], ";", "\[IndentingNewLine]", 
      RowBox[{"var0", "=", "xS"}], ";", " ", 
      RowBox[{"dvar0", "=", "dxS"}], ";", "\[IndentingNewLine]", 
      RowBox[{"comp\[Psi]", "=", "\"\<no\>\""}], ";", "\[IndentingNewLine]", 
      RowBox[{"comp\[Delta]", "=", "\"\<no\>\""}], ";", "\[IndentingNewLine]", 
      RowBox[{"segment", "[", 
       RowBox[{"\[CurlyPhi]Y", ",", "Ymax", ",", 
        RowBox[{"rMin", "->", "Ymin"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"varY", "=", "varL"}], ";", "\[IndentingNewLine]", 
      RowBox[{"varTab", "=", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"dvarTab", "=", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"yy", "=", 
          FractionBox["uV", 
           RowBox[{"Sin", "[", "\[CurlyPhi]Y", "]"}]]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"var0", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", "yy", "]"}], "&"}], "/@", "varY"}]}], ";", " ", 
         RowBox[{"dvar0", "=", 
          RowBox[{
           RowBox[{
            RowBox[{
             FractionBox["1", 
              SuperscriptBox["\[ExponentialE]", 
               RowBox[{"\[ImaginaryI]", " ", "\[CurlyPhi]Y"}]]], 
             RowBox[{
              RowBox[{"#", "'"}], "[", "yy", "]"}]}], "&"}], "/@", "varY"}]}],
          ";", "\[IndentingNewLine]", 
         RowBox[{"segment", "[", 
          RowBox[{"\[CurlyPhi]X", ",", 
           RowBox[{"reMax", "-", 
            FractionBox["uV", 
             RowBox[{"Tan", "[", "\[CurlyPhi]Y", "]"}]]}], ",", 
           RowBox[{"rMin", "->", 
            RowBox[{"reMin", "-", 
             FractionBox["uV", 
              RowBox[{"Tan", "[", "\[CurlyPhi]Y", "]"}]]}]}]}], "]"}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"varTab", ",", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"uH", "+", 
                  RowBox[{"Re", "[", "uO", "]"}]}], ",", 
                 RowBox[{"uV", "+", 
                  RowBox[{"Im", "[", "uO", "]"}]}]}], "}"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"uH", "-", 
                   FractionBox["uV", 
                    RowBox[{"Tan", "[", "\[CurlyPhi]Y", "]"}]]}], "]"}], 
                 "&"}], "/@", "varL"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"uH", ",", "reMin", ",", "reMax", ",", 
               FractionBox[
                RowBox[{"reMax", "-", "reMin"}], "rePoints"]}], "}"}]}], 
            "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"dvarTab", ",", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"uH", "+", 
                  RowBox[{"Re", "[", "uO", "]"}]}], ",", 
                 RowBox[{"uV", "+", 
                  RowBox[{"Im", "[", "uO", "]"}]}]}], "}"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  FractionBox["1", 
                   SuperscriptBox["\[ExponentialE]", 
                    RowBox[{"\[ImaginaryI]", " ", "\[CurlyPhi]X"}]]], 
                  RowBox[{
                   RowBox[{"#", "'"}], "[", 
                   RowBox[{"uH", "-", 
                    FractionBox["uV", 
                    RowBox[{"Tan", "[", "\[CurlyPhi]Y", "]"}]]}], "]"}]}], 
                 "&"}], "/@", "varL"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"uH", ",", "reMin", ",", "reMax", ",", 
               FractionBox[
                RowBox[{"reMax", "-", "reMin"}], "rePoints"]}], "}"}]}], 
            "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
        "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"uV", ",", "imMin", ",", "imMax", ",", 
          FractionBox[
           RowBox[{"imMax", "-", "imMin"}], "imPoints"]}], "}"}]}], "]"}], 
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"ToExpression", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ToString", "[", "#", "]"}], "<>", "\"\<Inter\>\""}], ",", 
          "StandardForm", ",", 
          RowBox[{"Function", "[", 
           RowBox[{"s", ",", 
            RowBox[{"Clear", "[", "s", "]"}], ",", "HoldAll"}], "]"}]}], 
         "]"}], "&"}], "/@", "var"}], ";", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Evaluate", "[", 
          RowBox[{"Symbol", "[", 
           RowBox[{
            RowBox[{"ToString", "[", 
             RowBox[{"var", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "<>", "\"\<Inter\>\""}], 
           "]"}], "]"}], "=", 
         RowBox[{"Interpolation", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", 
              RowBox[{"#", "[", 
               RowBox[{"[", 
                RowBox[{"2", ",", "i"}], "]"}], "]"}]}], "}"}], "&"}], "/@", 
           RowBox[{"Flatten", "[", 
            RowBox[{"varTab", ",", "1"}], "]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "var", "]"}]}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"ToExpression", "[", 
         RowBox[{
          RowBox[{"\"\<d\>\"", "<>", 
           RowBox[{"ToString", "[", "#", "]"}], "<>", "\"\<Inter\>\""}], ",", 
          "StandardForm", ",", 
          RowBox[{"Function", "[", 
           RowBox[{"s", ",", 
            RowBox[{"Clear", "[", "s", "]"}], ",", "HoldAll"}], "]"}]}], 
         "]"}], "&"}], "/@", "var"}], ";", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Evaluate", "[", 
          RowBox[{"Symbol", "[", 
           RowBox[{"\"\<d\>\"", "<>", 
            RowBox[{"ToString", "[", 
             RowBox[{"var", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "<>", "\"\<Inter\>\""}], 
           "]"}], "]"}], "=", 
         RowBox[{"Interpolation", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", 
              RowBox[{"#", "[", 
               RowBox[{"[", 
                RowBox[{"2", ",", "i"}], "]"}], "]"}]}], "}"}], "&"}], "/@", 
           RowBox[{"Flatten", "[", 
            RowBox[{"dvarTab", ",", "1"}], "]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "var", "]"}]}], "}"}]}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
