Cell[BoxData[
 RowBox[{"(*", "\"\< \nclickPane[] creates ClickPanes with the Riemann-sheet \
plots of x(u) and t(u) as background,\nallowing the branch points to be \
located.\n\nClicking on a pane adds segments to a piecewise straight-line \
contour.\n\nClicking near the left (right) border adds the asymptotic \
antiparticle (particle) segment.  \n\>\"", "*)"}]], "Input",
 CellChangeTimes->{{3.9910403950527534`*^9, 3.9910406263817863`*^9}, {
  3.9910457397483654`*^9, 3.991045767755993*^9}, {3.9910467265555*^9, 
  3.9910467406756134`*^9}},ExpressionUUID->"7d6942cd-d349-8548-9412-\
7d3e46aebdda"],

Cell[BoxData[
 RowBox[{
  RowBox[{"clickPane", "[", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pts", "=", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], "}"}]}], ";", " ", 
     RowBox[{"nm", "=", "1"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ClickPane", "[", 
       RowBox[{
        RowBox[{"Dynamic", "[", 
         RowBox[{"Show", "[", 
          RowBox[{"xPlot", ",", 
           RowBox[{"Graphics", "[", 
            RowBox[{"{", 
             RowBox[{"Green", ",", 
              RowBox[{"Thickness", "[", ".005", "]"}], ",", 
              RowBox[{"Line", "[", "pts", "]"}]}], "}"}], "]"}], ",", 
           RowBox[{"PlotRange", "->", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"ReMin", ",", "ReMax"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"ImMin", ",", "ImMax"}], "}"}]}], "}"}]}]}], "]"}], 
         "]"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Which", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{
              RowBox[{"1", "-", 
               FractionBox[
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "ReMin"]}], "<", ".07"}], ",",
              "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"AppendTo", "[", 
               RowBox[{"pts", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "100"}], ",", 
                  RowBox[{"pts", "[", 
                   RowBox[{"[", 
                    RowBox[{
                    RowBox[{"-", "1"}], ",", "2"}], "]"}], "]"}]}], "}"}]}], 
               "]"}], ";", " ", 
              RowBox[{"\[CurlyPhi]InTab", "=", 
               RowBox[{
                RowBox[{
                 RowBox[{"ArcTan", "[", 
                  RowBox[{"#1", ",", "#2"}], "]"}], "&"}], "@@@", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"RotateLeft", "[", "pts", "]"}], "-", "pts"}], 
                  ")"}], "[", 
                 RowBox[{"[", 
                  RowBox[{"1", ";;", 
                   RowBox[{"-", "2"}]}], "]"}], "]"}]}]}], ";", 
              RowBox[{"rInTab", "=", 
               RowBox[{
                RowBox[{
                 RowBox[{"Norm", "[", "#", "]"}], "&"}], "/@", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"RotateLeft", "[", "pts", "]"}], "-", "pts"}], 
                  ")"}], "[", 
                 RowBox[{"[", 
                  RowBox[{"1", ";;", 
                   RowBox[{"-", "2"}]}], "]"}], "]"}]}]}], ";", " ", 
