      {"0", "\[ImaginaryI]", "0", "0"},
      {"\[ImaginaryI]", "0", "0", "0"},
      {"0", "0", "0", "\[ImaginaryI]"},
      {"0", "0", "\[ImaginaryI]", "0"}
     }], ")"}]}], ";", " ", 
  RowBox[{"g2", "=", 
   RowBox[{"(", GridBox[{
      {
       RowBox[{"-", "\[ImaginaryI]"}], "0", "0", "0"},
      {"0", "\[ImaginaryI]", "0", "0"},
      {"0", "0", "\[ImaginaryI]", "0"},
      {"0", "0", "0", 
       RowBox[{"-", "\[ImaginaryI]"}]}
     }], ")"}]}], ";", " ", 
  RowBox[{"g3", "=", 
   RowBox[{"(", GridBox[{
      {"0", "0", 
       RowBox[{"-", "\[ImaginaryI]"}], "0"},
      {"0", "0", "0", "\[ImaginaryI]"},
      {
       RowBox[{"-", "\[ImaginaryI]"}], "0", "0", "0"},
      {"0", "\[ImaginaryI]", "0", "0"}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "=", 
   RowBox[{"{", 
    RowBox[{"g0", ",", "g1", ",", "g2", ",", "g3"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"id", "=", 
   RowBox[{"IdentityMatrix", "[", "4", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g5", "=", 
   RowBox[{"\[ImaginaryI]", " ", 
    RowBox[{"g0", ".", "g1", ".", "g2", ".", "g3"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"R1", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}]}], ";", " ", 
  RowBox[{"R2", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"u1", "[", 
    RowBox[{"P1_", ",", "P2_", ",", "P3_"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"2", "P0", 
        RowBox[{"(", 
         RowBox[{"P0", "+", "P1"}], ")"}]}]]], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"P0", " ", "g0"}], "+", 
        RowBox[{"P1", " ", "g1"}], "+", 
        RowBox[{"P2", " ", "g2"}], "+", 
        RowBox[{"P3", " ", "g3"}], "+", "id"}], ")"}], ".", "R1"}]}], "/.", 
    RowBox[{"{", 
     RowBox[{"P0", "->", 
      SqrtBox[
       RowBox[{"1", "+", 
        SuperscriptBox["P1", "2"], "+", 
        SuperscriptBox["P2", "2"], "+", 
        SuperscriptBox["P3", "2"]}]]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"u2", "[", 
    RowBox[{"P1_", ",", "P2_", ",", "P3_"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"2", "P0", 
        RowBox[{"(", 
         RowBox[{"P0", "+", "P1"}], ")"}]}]]], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"P0", " ", "g0"}], "+", 
        RowBox[{"P1", " ", "g1"}], "+", 
        RowBox[{"P2", " ", "g2"}], "+", 
        RowBox[{"P3", " ", "g3"}], "+", "id"}], ")"}], ".", "R2"}]}], "/.", 
    RowBox[{"{", 
     RowBox[{"P0", "->", 
      SqrtBox[
       RowBox[{"1", "+", 
        SuperscriptBox["P1", "2"], "+", 
        SuperscriptBox["P2", "2"], "+", 
        SuperscriptBox["P3", "2"]}]]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"v1", "[", 
    RowBox[{"P1_", ",", "P2_", ",", "P3_"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"2", "P0", 
        RowBox[{"(", 
         RowBox[{"P0", "+", "P1"}], ")"}]}]]], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "P0"}], " ", "g0"}], "-", 
        RowBox[{"P1", " ", "g1"}], "-", 
        RowBox[{"P2", " ", "g2"}], "-", 
        RowBox[{"P3", " ", "g3"}], "+", "id"}], ")"}], ".", "R1"}]}], "/.", 
    RowBox[{"{", 
     RowBox[{"P0", "->", 
      SqrtBox[
       RowBox[{"1", "+", 
        SuperscriptBox["P1", "2"], "+", 
        SuperscriptBox["P2", "2"], "+", 
        SuperscriptBox["P3", "2"]}]]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"v2", "[", 
    RowBox[{"P1_", ",", "P2_", ",", "P3_"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"2", "P0", 
        RowBox[{"(", 
         RowBox[{"P0", "+", "P1"}], ")"}]}]]], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "P0"}], " ", "g0"}], "-", 
        RowBox[{"P1", " ", "g1"}], "-", 
        RowBox[{"P2", " ", "g2"}], "-", 
        RowBox[{"P3", " ", "g3"}], "+", "id"}], ")"}], ".", "R2"}]}], "/.", 
    RowBox[{"{", 
     RowBox[{"P0", "->", 
      SqrtBox[
       RowBox[{"1", "+", 
        SuperscriptBox["P1", "2"], "+", 
        SuperscriptBox["P2", "2"], "+", 
        SuperscriptBox["P3", "2"]}]]}], "}"}]}]}], ";"}]}], "Input",
