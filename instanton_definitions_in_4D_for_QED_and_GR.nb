                 RowBox[{"nm", ";;", 
                  RowBox[{"-", "1"}]}], "]"}], "]"}]}], ";"}], ",", 
             "\[IndentingNewLine]", "True", ",", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"pts", ",", "#"}], "]"}]}], "]"}], ";"}], ")"}], 
         "&"}]}], "]"}], "//", "Echo"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ClickPane", "[", 
       RowBox[{
