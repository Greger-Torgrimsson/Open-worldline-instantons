                  RowBox[{"#", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], ",", "ImMax"}], "}"}]}], 
               "]"}], ";", " ", 
              RowBox[{"ptsIn", "=", "pts"}], ";", " ", 
              RowBox[{"nm", "=", 
               RowBox[{"Length", "[", "pts", "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"pts", "=", 
               RowBox[{"Reverse", "[", "pts", "]"}]}], ";"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"1", "-", 
