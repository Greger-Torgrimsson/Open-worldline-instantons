               RowBox[{"Reverse", "[", "pts", "]"}]}], ";"}], 
             "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"1", "-", 
               FractionBox[
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "ReMax"]}], "<", ".07"}], ",", 
             RowBox[{
              RowBox[{"AppendTo", "[", 
               RowBox[{"pts", ",", 
                RowBox[{"{", 
