 RowBox[{
  RowBox[{
   RowBox[{"quad", "[", "x_", "]"}], "=", 
   RowBox[{"c0", "+", 
    RowBox[{"c1", " ", "x"}], "+", 
    RowBox[{"c2", " ", 
     SuperscriptBox["x", "2"]}]}]}], ";"}]], "Input",
