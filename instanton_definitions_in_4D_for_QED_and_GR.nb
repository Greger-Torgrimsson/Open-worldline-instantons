                  RowBox[{"pts", "[", 
                   RowBox[{"[", 
                    RowBox[{
                    RowBox[{"-", "1"}], ",", "2"}], "]"}], "]"}]}], "}"}]}], 
               "]"}], ";", " ", 
              RowBox[{"\[CurlyPhi]InTab", "=", 
               RowBox[{
                RowBox[{
                 RowBox[{"ArcTan", "[", 
                  RowBox[{"#1", ",", "#2"}], "]"}], "&"}], "@@@", 
