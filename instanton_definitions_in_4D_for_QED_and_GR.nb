Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"xu", "=", 
    SuperscriptBox["x", "\[Mu]"]}], ",", " ", 
   RowBox[{"gdd", "=", 
    SubscriptBox["g", "\[Mu]\[Nu]"]}], ",", " ", 
   RowBox[{"guu", "=", 
    SuperscriptBox["g", "\[Mu]\[Nu]"]}], ",", " ", 
   RowBox[{
    RowBox[{"gddd", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"\[Mu]", "+", "1"}], ",", 
       RowBox[{"\[Nu]", "+", "1"}], ",", 
       RowBox[{"\[Rho]", "+", "1"}]}], "]"}], "]"}], "=", 
    SubscriptBox["g", 
     RowBox[{"\[Mu]\[Nu]", ",", "\[Rho]"}]]}], ",", " ", 
   RowBox[{
    RowBox[{"\[CapitalGamma]udd", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"\[Mu]", "+", "1"}], ",", 
       RowBox[{"\[Nu]", "+", "1"}], ",", 
       RowBox[{"\[Rho]", "+", "1"}]}], "]"}], "]"}], "=", 
    SubsuperscriptBox["\[CapitalGamma]", "\[Nu]\[Rho]", "\[Mu]"]}], ",", " ", 
   RowBox[{
    RowBox[{"\[CapitalGamma]uddd", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"\[Mu]", "+", "1"}], ",", 
       RowBox[{"\[Nu]", "+", "1"}], ",", 
       RowBox[{"\[Rho]", "+", "1"}], ",", 
       RowBox[{"\[Sigma]", "+", "1"}]}], "]"}], "]"}], "=", 
    SubsuperscriptBox["\[CapitalGamma]", 
     RowBox[{"\[Nu]\[Rho]", ",", "\[Sigma]"}], "\[Mu]"]}], ",", " ", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Add", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"\[Mu]", "+", "1"}], ",", 
       RowBox[{"\[Nu]", "+", "1"}]}], "]"}], "]"}], "=", 
    SubscriptBox["A", 
     RowBox[{"\[Mu]", ",", "\[Nu]"}]]}], ",", " ", 
   RowBox[{
    RowBox[{"Fud", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"\[Mu]", "+", "1"}], ",", 
       RowBox[{"\[Nu]", "+", "1"}]}], "]"}], "]"}], "=", 
    RowBox[{
     SubsuperscriptBox["F", "\[Nu]", "\[Mu]"], "=", 
     RowBox[{
      SuperscriptBox["g", "\[Mu]\[Rho]"], 
      SubscriptBox["F", "\[Rho]\[Nu]"]}]}]}], ",", " ", 
   RowBox[{
    SubscriptBox["F", "\[Mu]\[Nu]"], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["d", "\[Mu]"], 
      SubscriptBox["A", "\[Nu]"]}], "-", 
     RowBox[{
      SubscriptBox["d", "\[Nu]"], 
      SubscriptBox["A", "\[Mu]"]}]}]}], ",", " ", 
   RowBox[{
    RowBox[{"Fudd", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"\[Mu]", "+", "1"}], ",", 
       RowBox[{"\[Nu]", "+", "1"}], ",", 
       RowBox[{"\[Rho]", "+", "1"}]}], "]"}], "]"}], "=", 
    RowBox[{
     SubsuperscriptBox["F", 
      RowBox[{"\[Nu]", ",", "\[Rho]"}], "\[Mu]"], "=", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["g", "\[Mu]\[Sigma]"], 
        SubscriptBox["F", "\[Sigma]\[Nu]"]}], ")"}], 
      RowBox[{",", "\[Rho]"}]]}]}]}], " ", "*)"}]], "Input",
 CellChangeTimes->{{3.9826680682603283`*^9, 3.982668104414751*^9}, {
  3.982668330809887*^9, 3.982668376848505*^9}, {3.982668489535152*^9, 
  3.982668518851869*^9}, {3.9826687022054214`*^9, 3.982668738060034*^9}, {
